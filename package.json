{
  "name": "rageval-forge",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Pure Node.js RAG evaluation workflows for DeepLocals, Cherry Studio, and UI-driven platforms.",
  "bin": {
    "rageval": "./bin/rageval.js"
